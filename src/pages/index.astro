---
import { social, homeBlocks } from '../config';

---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="evie makes — coming soon" />
    <title>evie makes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>

    <div class="bg-shapes">
      {homeBlocks.map((block) => (
        <div class="sf">
          {block.href ? (
            <a href={block.href} class="img-block" aria-label={block.alt} data-answer={block.answer}>
              <img src={block.image} alt="" />
            </a>
          ) : (
            <div class="img-block">
              <img src={block.image} alt={block.alt} />
            </div>
          )}
        </div>
      ))}
    </div>

    <main>
      <h1 class="brand">
        evie<span class="star" aria-hidden="true">✦</span>makes
      </h1>

      <div class="accent-blocks" aria-hidden="true">
        <span class="ab coral"></span>
        <span class="ab teal"></span>
        <span class="ab lav"></span>
      </div>

      <p class="tagline">hey! i'm evangeline. i like making things... here are some of them :)</p>

      <div class="pips" aria-hidden="true">
        <span class="pip lav"></span>
        <span class="pip coral"></span>
        <span class="pip teal"></span>
      </div>

      <nav class="links" aria-label="Social links">
        <a
          href={social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-li"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <rect x="2" y="2" width="20" height="20" rx="3"/>
            <path d="M7 10v7M7 7v.01M12 17v-4a2 2 0 0 1 4 0v4M12 10v7"/>
          </svg>
          LinkedIn
        </a>
        <a
          href={social.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ig"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <circle cx="12" cy="12" r="4"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
          </svg>
          Instagram
        </a>
      </nav>
    </main>

  </body>
</html>

<script>
  // ─── Seeded PRNG (mulberry32) ───
  function mulberry32(seed: number) {
    return () => {
      seed = (seed + 0x6D2B79F5) | 0;
      let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  function rectsOverlap(
    a: { left: number; top: number; right: number; bottom: number },
    b: { left: number; top: number; right: number; bottom: number },
    margin = 0
  ) {
    return !(
      a.right  + margin < b.left  ||
      a.left   > b.right + margin ||
      a.bottom + margin < b.top   ||
      a.top    > b.bottom + margin
    );
  }

  const SEED     = 42;
  const MARGIN   = 24;
  const EDGE_PAD = 20;

  function layout(isResize = false) {
    const wrappers = Array.from(document.querySelectorAll<HTMLElement>('.sf'));
    if (!wrappers.length) return;

    if (!isResize) {
      wrappers.forEach(w => {
        w.classList.remove('placed');
        w.style.left = '';
        w.style.top  = '';
      });
    }

    const rand = mulberry32(SEED);
    const card = document.querySelector<HTMLElement>('main');
    if (!card) return;
    const cr = card.getBoundingClientRect();

    const vw = window.innerWidth;
    const vh = window.innerHeight;
    const placed: { left: number; top: number; right: number; bottom: number }[] = [];

    for (const wrapper of wrappers) {
      const block = wrapper.querySelector<HTMLElement>('.img-block');
      if (!block) continue;

      const w = block.offsetWidth;
      const h = block.offsetHeight;

      let fx: number | null = null;
      let fy: number | null = null;

      for (let attempt = 0; attempt < 300; attempt++) {
        const x = EDGE_PAD + rand() * (vw - w - EDGE_PAD * 2);
        const y = EDGE_PAD + rand() * (vh - h - EDGE_PAD * 2);
        const rect = { left: x, top: y, right: x + w, bottom: y + h };

        if (rectsOverlap(rect, { left: cr.left, top: cr.top, right: cr.right, bottom: cr.bottom }, MARGIN)) continue;
        if (placed.some(p => rectsOverlap(rect, p, MARGIN))) continue;

        fx = x; fy = y;
        placed.push(rect);
        break;
      }

      if (fx !== null && fy !== null) {
        wrapper.style.left = `${Math.round(fx)}px`;
        wrapper.style.top  = `${Math.round(fy)}px`;
        if (!isResize) wrapper.classList.add('placed');
      }
      // If 300 attempts fail the image stays where it was (resize) or hidden (initial).
      // Future: push into a scroll zone below the viewport.
    }
  }

  async function init() {
    const imgs = Array.from(document.querySelectorAll<HTMLImageElement>('.sf img'));
    await Promise.all(imgs.map(img => img.decode().catch(() => {})));
    layout(false);
  }

  document.fonts.ready.then(() => {
    document.body.classList.add('fonts-ready');
  });

  document.querySelectorAll<HTMLAnchorElement>('[data-answer]').forEach(el => {
    el.addEventListener('click', () => {
      sessionStorage.setItem('wip-answer', el.dataset.answer!);
    });
  });

  init();

  let rafId: number | null = null;
  let settleTimer: ReturnType<typeof setTimeout> | null = null;

  window.addEventListener('resize', () => {
    // Live feedback every frame while resizing
    if (rafId !== null) cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(() => {
      layout(true);
      rafId = null;
    });

    // Accurate final placement after resize settles (main has reflowed by then)
    if (settleTimer !== null) clearTimeout(settleTimer);
    settleTimer = setTimeout(() => {
      layout(true);
      settleTimer = null;
    }, 150);
  });
</script>

<style>
  :root {
    --yellow: #FFE141;
    --coral: #FF3358;
    --teal: #00C9B1;
    --lav: #C4B5FD;
    --ink: #1A1A1A;
    --white: #FFFFFF;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
  }

  body {
    min-height: 100vh;
    background-color: var(--yellow);
    background-image: radial-gradient(rgba(26, 26, 26, 0.1) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-family: 'Unbounded', sans-serif;
  }

  /* ─── Floating background shapes ─── */
  .bg-shapes {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .sf {
    position: absolute;
    pointer-events: none;
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .sf.placed {
    visibility: visible;
    opacity: 1;
    transition: opacity 0.5s ease, left 0.3s ease, top 0.3s ease;
  }

  .img-block {
    display: block;
    width: 220px;
    pointer-events: all;
    transform: rotate(-1.8deg);
    transition: transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1);
    text-decoration: none;
  }

  a.img-block:hover,
  .img-block:hover {
    transform: rotate(0deg) translateY(-10px);
  }

  .img-block img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ─── Main ─── */
  main {
    position: relative;
    z-index: 10;
    padding: 2.75rem 3rem;
    max-width: 460px;
    border: 4px solid var(--ink);
    border-radius: 28px;
    box-shadow: 8px 8px 0 var(--ink);
    animation: wrapperEnter 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-play-state: paused;
  }

  body.fonts-ready main {
    animation-play-state: running;
  }

  @keyframes wrapperEnter {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.88);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ─── Brand name ─── */
  .brand {
    font-family: 'Unbounded', sans-serif;
    font-weight: 900;
    font-size: clamp(2.4rem, 8vw, 3.75rem);
    color: var(--coral);
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: lowercase;
    animation: staggerIn 0.5s 0.35s both;
    animation-play-state: paused;
  }

  body.fonts-ready .brand {
    animation-play-state: running;
  }

  .star {
    display: inline-block;
    color: var(--teal);
    font-size: 0.55em;
    vertical-align: middle;
    margin: 0 0.08em;
    animation: spinStar 10s linear infinite;
  }

  @keyframes spinStar {
    to { transform: rotate(360deg); }
  }

  /* ─── Accent color blocks ─── */
  .accent-blocks {
    display: flex;
    gap: 7px;
    margin: 1.5rem 0 1.3rem;
    animation: staggerIn 0.5s 0.48s both;
    animation-play-state: paused;
  }

  body.fonts-ready .accent-blocks {
    animation-play-state: running;
  }

  .ab {
    height: 9px;
    border-radius: 5px;
    border: 2px solid var(--ink);
  }

  .ab.coral  { background: var(--coral); flex: 2; }
  .ab.teal   { background: var(--teal);  flex: 3; }
  .ab.lav    { background: var(--lav);   flex: 1.5; }

  /* ─── Tagline ─── */
  .tagline {
    font-family: 'Unbounded', sans-serif;
    font-size: clamp(0.75rem, 2.5vw, 1rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1.2;
    animation: staggerIn 0.5s 0.58s both;
    animation-play-state: paused;
  }

  body.fonts-ready .tagline {
    animation-play-state: running;
  }

  /* ─── Pips ─── */
  .pips {
    display: flex;
    gap: 7px;
    margin: 1.3rem 0 1.6rem;
    animation: staggerIn 0.5s 0.68s both;
    animation-play-state: paused;
  }

  body.fonts-ready .pips {
    animation-play-state: running;
  }

  .pip {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2px solid var(--ink);
  }

  .pip.lav   { background: var(--lav); }
  .pip.coral { background: var(--coral); }
  .pip.teal  { background: var(--teal); }

  /* ─── Links ─── */
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    animation: staggerIn 0.5s 0.78s both;
    animation-play-state: paused;
  }

  body.fonts-ready .links {
    animation-play-state: running;
  }

  /* ─── Buttons ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 20px;
    border: 3px solid var(--ink);
    border-radius: 100px;
    background: var(--ink);
    color: var(--yellow);
    font-family: 'Unbounded', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 4px 4px 0 rgba(26, 26, 26, 0.3);
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.22s ease;
  }

  .btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .btn:hover {
    transform: translateY(-6px);
    box-shadow: 7px 7px 0 rgba(26, 26, 26, 0.3);
  }

  .btn-li {
    background: #0A66C2;
    color: var(--white);
    border-color: #0A66C2;
  }

  .btn-ig {
    background: #E1306C;
    color: var(--white);
    border-color: #E1306C;
  }

  /* ─── Stagger entrance animation ─── */
  @keyframes staggerIn {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─── Responsive ─── */
  @media (max-width: 380px) {
    .links {
      flex-direction: column;
    }
    .btn {
      justify-content: center;
    }
  }
</style>
