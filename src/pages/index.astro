        <a href="/projects/pool-games" class="s7" aria-label="Pool games — project">
          <svg class="pool-icon" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="32" cy="32" r="21" fill="#FFE141"/>
            <circle cx="32" cy="32" r="9" fill="#1A1A1A"/>
            <text x="32" y="36" text-anchor="middle" font-size="10" font-weight="900" font-family="system-ui, sans-serif" fill="white">8</text>
