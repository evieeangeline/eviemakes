<script>
  function addFloatHover(wrapperSel: string, anchorSel: string) {
    const wrapper = document.querySelector(wrapperSel) as HTMLElement;
    const anchor = document.querySelector(anchorSel) as HTMLElement;
    if (!wrapper || !anchor) return;

    anchor.addEventListener('mouseenter', () => {
      const current = window.getComputedStyle(wrapper).transform;
      wrapper.style.animation = 'none';
      wrapper.style.transform = current;
      requestAnimationFrame(() => requestAnimationFrame(() => {
        wrapper.style.transition = 'transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1)';
        wrapper.style.transform = 'none';
      }));
    });

    anchor.addEventListener('mouseleave', () => {
      wrapper.style.transition = '';
      wrapper.style.animation = '';
      wrapper.style.transform = '';
    });
  }

  addFloatHover('.sf5', '.s5');
  addFloatHover('.sf6', '.s6');
  addFloatHover('.sf7', '.s7');
</script>

<style>
  :root {
    --yellow: #FFE141;
    --coral: #FF3358;
    --teal: #00C9B1;
    --lav: #C4B5FD;
    --ink: #1A1A1A;
    --white: #FFFFFF;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    height: 100%;
  }

  body {
    min-height: 100vh;
    background-color: var(--yellow);
    background-image: radial-gradient(rgba(26, 26, 26, 0.1) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    font-family: 'Unbounded', sans-serif;
  }

  /* ─── Floating background shapes ─── */
  .bg-shapes {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .sf5 {
    position: absolute;
    top: 54%; left: 2%;
    animation: floatB 10s ease-in-out infinite reverse;
    pointer-events: none;
  }

  .shape {
    position: absolute;
    border: 3px solid rgba(26, 26, 26, 0.18);
  }

  .s1 {
    width: 68px; height: 68px;
    background: var(--coral);
    border-radius: 22px;
    top: 9%; left: 7%;
    animation: floatA 7s ease-in-out infinite;
  }
  .s2 {
    width: 46px; height: 46px;
    background: var(--teal);
    border-radius: 14px;
    top: 17%; right: 10%;
    animation: floatB 9s ease-in-out infinite;
  }
  .s3 {
    width: 58px; height: 58px;
    background: var(--lav);
    border-radius: 18px;
    bottom: 24%; left: 5%;
    animation: floatC 8s ease-in-out infinite;
  }
  .s4 {
    width: 36px; height: 36px;
    background: var(--white);
    border-radius: 11px;
    bottom: 13%; right: 7%;
    animation: floatA 6s ease-in-out infinite reverse;
  }
  .s5 {
    width: 84px; height: 84px;
    background: rgba(0, 201, 177, 0.65);
    border-radius: 24px;
    border: 3px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: all;
    box-shadow: 4px 4px 0 var(--ink);
    transition: transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.15s ease, box-shadow 0.3s ease;
    text-decoration: none;
  }

  .s5:hover {
    background: rgba(0, 201, 177, 0.9);
    transform: translateY(-8px);
    box-shadow: 8px 8px 0 var(--ink);
  }

  .fish-icon {
    width: 58px;
    height: 58px;
  }
  .sf6 {
    position: absolute;
    top: 7%; right: 4%;
    animation: floatC 8s ease-in-out infinite;
    pointer-events: none;
  }

  .s6 {
    width: 68px; height: 68px;
    background: rgba(255, 51, 88, 0.65);
    border-radius: 20px;
    border: 3px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: all;
    box-shadow: 4px 4px 0 var(--ink);
    transition: transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.15s ease, box-shadow 0.3s ease;
    text-decoration: none;
  }

  .s6:hover {
    background: rgba(255, 51, 88, 0.9);
    transform: translateY(-8px);
    box-shadow: 8px 8px 0 var(--ink);
  }

  .boat-icon {
    width: 48px;
    height: 48px;
  }
  .sf7 {
    position: absolute;
    bottom: 9%; left: 22%;
    animation: floatA 7.5s ease-in-out infinite;
    pointer-events: none;
  }

  .s7 {
    width: 62px; height: 62px;
    background: rgba(196, 181, 253, 0.75);
    border-radius: 18px;
    border: 3px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    pointer-events: all;
    box-shadow: 4px 4px 0 var(--ink);
    transition: transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1), background 0.15s ease, box-shadow 0.3s ease;
    text-decoration: none;
  }

  .s7:hover {
    background: rgba(196, 181, 253, 0.95);
    transform: translateY(-8px);
    box-shadow: 8px 8px 0 var(--ink);
  }

  .pool-icon {
    width: 44px;
    height: 44px;
  }

  @keyframes floatA {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50%       { transform: translateY(-22px) rotate(9deg); }
  }
  @keyframes floatB {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    33%      { transform: translateY(-14px) rotate(-6deg); }
    66%      { transform: translateY(10px) rotate(11deg); }
  }
  @keyframes floatC {
    0%, 100% { transform: translateX(0) rotate(0deg); }
    50%      { transform: translateX(20px) rotate(-12deg); }
  }

  /* ─── Main ─── */
  main {
    position: relative;
    z-index: 10;
    padding: 2rem;
  }

  /* ─── Card wrapper: handles entrance ─── */
  .card-wrapper {
    animation: wrapperEnter 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  @keyframes wrapperEnter {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.88);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* ─── Card ─── */
  .card {
    background-color: var(--white);
    background-image: radial-gradient(rgba(26, 26, 26, 0.04) 1px, transparent 1px);
    background-size: 18px 18px;
    border: 4px solid var(--ink);
    border-radius: 28px;
    box-shadow: 8px 8px 0 var(--ink);
    padding: 2.75rem 3rem;
    max-width: 460px;
    width: 100%;
    transform: rotate(-1.8deg);
    transition:
      transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease;
    cursor: default;
  }

  .card:hover {
    transform: rotate(0deg) translateY(-10px);
    box-shadow: 14px 14px 0 var(--ink);
  }

  /* ─── Brand name ─── */
  .brand {
    font-family: 'Unbounded', sans-serif;
    font-weight: 900;
    font-size: clamp(2.4rem, 8vw, 3.75rem);
    color: var(--coral);
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: lowercase;
    animation: staggerIn 0.5s 0.35s both;
  }

  .star {
    display: inline-block;
    color: var(--teal);
    font-size: 0.55em;
    vertical-align: middle;
    margin: 0 0.08em;
    animation: spinStar 10s linear infinite;
  }

  @keyframes spinStar {
    to { transform: rotate(360deg); }
  }

  /* ─── Accent color blocks ─── */
  .accent-blocks {
    display: flex;
    gap: 7px;
    margin: 1.5rem 0 1.3rem;
    animation: staggerIn 0.5s 0.48s both;
  }

  .ab {
    height: 9px;
    border-radius: 5px;
    border: 2px solid var(--ink);
  }

  .ab.coral  { background: var(--coral); flex: 2; }
  .ab.teal   { background: var(--teal);  flex: 3; }
  .ab.lav    { background: var(--lav);   flex: 1.5; }

  /* ─── Tagline ─── */
  .tagline {
    font-family: 'Caveat', cursive;
    font-size: clamp(1.3rem, 4vw, 1.8rem);
    font-weight: 400;
    color: var(--ink);
    line-height: 1.2;
    animation: staggerIn 0.5s 0.58s both;
  }

  /* ─── Pips ─── */
  .pips {
    display: flex;
    gap: 7px;
    margin: 1.3rem 0 1.6rem;
    animation: staggerIn 0.5s 0.68s both;
  }

  .pip {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2px solid var(--ink);
  }

  .pip.lav   { background: var(--lav); }
  .pip.coral { background: var(--coral); }
  .pip.teal  { background: var(--teal); }

  /* ─── Links ─── */
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    animation: staggerIn 0.5s 0.78s both;
  }

  /* ─── Buttons ─── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 20px;
    border: 3px solid var(--ink);
    border-radius: 100px;
    background: var(--white);
    color: var(--ink);
    font-family: 'Unbounded', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 4px 4px 0 var(--ink);
    transition:
      transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.22s ease,
      background 0.15s ease,
      color 0.15s ease;
  }

  .btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: color 0.15s ease;
  }

  .btn:hover {
    transform: translateY(-6px);
    box-shadow: 7px 7px 0 var(--ink);
  }

  .btn-li:hover {
    background: #0A66C2;
    color: var(--white);
  }

  .btn-ig:hover {
    background: #E1306C;
    color: var(--white);
  }

  /* ─── Stagger entrance animation ─── */
  @keyframes staggerIn {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─── Responsive ─── */
  @media (max-width: 380px) {
    .card {
      padding: 2rem 1.75rem;
      border-radius: 22px;
    }
    .links {
      flex-direction: column;
    }
    .btn {
      justify-content: center;
    }
  }
</style>
