<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content="still building — evie makes" />
    <title>still building — evie makes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@700;900&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <div class="card">
        <div class="header">
          <h1 class="title">work in progress!</h1>
          <p class="subtitle">in the meantime, can you guess the name of the page?</p>
        </div>

        <div class="grid" id="grid"></div>

        <p class="instruct">type · backspace · enter to guess</p>

        <div class="result" id="result"></div>
      </div>

      <a href="/" class="back">← back home</a>
    </main>
  </body>
</html>

<script>
  const ANSWER  = sessionStorage.getItem('wip-answer') || 'POOL GAMES';
  sessionStorage.removeItem('wip-answer');
  const UP      = ANSWER.toUpperCase();
  const WORDS   = UP.split(' ');                    // ['POOL', 'GAMES']
  const LETTERS = UP.replace(/ /g, '');             // 'POOLGAMES'
  const N       = LETTERS.length;                   // 9

  // ─── State ───────────────────────────────────────────────────────────────
  let guesses = [];   // { letters: string[], result: state[] }
  let current = [];   // letters being typed right now
  let won     = false;

  // ─── Logic ───────────────────────────────────────────────────────────────
  function evaluate(guess) {
    const out  = Array(N).fill('absent');
    const bank = LETTERS.split('');
    for (let i = 0; i < N; i++)
      if (guess[i] === bank[i]) { out[i] = 'correct'; bank[i] = '\0'; }
    for (let i = 0; i < N; i++) {
      if (out[i] === 'correct') continue;
      const j = bank.indexOf(guess[i]);
      if (j !== -1) { out[i] = 'present'; bank[j] = '\0'; }
    }
    return out;
  }

  function submit() {
    if (won || current.length < N) return;
    const result = evaluate([...current]);
    guesses.push({ letters: [...current], result });
    if (result.every(r => r === 'correct')) {
      won = true;
      setTimeout(launchConfetti, 180);
    }
    current = [];
    render();
  }

  function add(ch) {
    if (won || current.length >= N) return;
    current.push(ch);
    render();
  }

  function del() {
    if (won || !current.length) return;
    current.pop();
    render();
  }

  // ─── DOM ─────────────────────────────────────────────────────────────────
  function makeRow(letters, result) {
    const row = document.createElement('div');
    row.className = 'row';
    let li = 0;

    WORDS.forEach((word, wi) => {
      if (wi > 0) {
        const gap = document.createElement('div');
        gap.className = 'word-gap';
        row.appendChild(gap);
      }
      for (let c = 0; c < word.length; c++) {
        const cell = document.createElement('div');
        cell.className = 'cell';
        if (result) {
          // submitted row — show coloured result
          cell.textContent   = letters[li];
          cell.dataset.state = result[li];
        } else if (letters[li]) {
          // current row — letter typed but not yet submitted
          cell.textContent   = letters[li];
          cell.dataset.state = 'typed';
        }
        // else: empty cell — just grey block, no text
        row.appendChild(cell);
        li++;
      }
    });

    return row;
  }

  function render() {
    const grid = document.getElementById('grid');
    grid.innerHTML = '';

    // past guesses
    for (const g of guesses) {
      grid.appendChild(makeRow(g.letters, g.result));
    }

    // current input row
    if (!won) {
      grid.appendChild(makeRow(current, null));
    }

    // win message
    const res = document.getElementById('result');
    document.getElementById('instruct').hidden = won;
    if (won) {
      res.innerHTML =
        `<p class="msg-win">you got it!</p>` +
        `<p class="msg-sub">it's <em>${ANSWER.toLowerCase()}</em> — still building though :)</p>`;
    } else {
      res.innerHTML = '';
    }
  }

  // ─── Input ───────────────────────────────────────────────────────────────
  window.addEventListener('keydown', e => {
    if (e.metaKey || e.ctrlKey || e.altKey) return;
    if (e.key === 'Enter')     { e.preventDefault(); submit(); return; }
    if (e.key === 'Backspace') { e.preventDefault(); del();    return; }
    if (/^[A-Za-z]$/.test(e.key)) add(e.key.toUpperCase());
  });

  // ─── Confetti ────────────────────────────────────────────────────────────
  function launchConfetti() {
    const canvas = document.createElement('canvas');
    canvas.style.cssText =
      'position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:9999;';
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    document.body.appendChild(canvas);
    const c = canvas.getContext('2d');

    const COLORS = ['#FF3358','#00C9B1','#C4B5FD','#FFE141','#FF8C42','#ffffff'];
    const pieces = Array.from({ length: 160 }, () => {
      const circle = Math.random() > 0.55;
      return {
        x:       Math.random() * canvas.width,
        y:       -20 - Math.random() * canvas.height * 0.35,
        w:       circle ? 7 : 9 + Math.random() * 7,
        h:       circle ? 7 : 4 + Math.random() * 4,
        color:   COLORS[Math.floor(Math.random() * COLORS.length)],
        vx:      (Math.random() - 0.5) * 4,
        vy:      1.5 + Math.random() * 3.5,
        rot:     Math.random() * Math.PI * 2,
        vrot:    (Math.random() - 0.5) * 0.18,
        gravity: 0.04 + Math.random() * 0.05,
        circle,
        alpha:   1,
      };
    });

    const FADE_START = 2800, TOTAL = 3600;
    let t0 = null;

    (function tick(ts) {
      if (!t0) t0 = ts;
      const elapsed = ts - t0;
      c.clearRect(0, 0, canvas.width, canvas.height);
      let alive = false;

      for (const p of pieces) {
        p.vy  += p.gravity;
        p.x   += p.vx;
        p.y   += p.vy;
        p.rot += p.vrot;
        if (elapsed > FADE_START)
          p.alpha = Math.max(0, 1 - (elapsed - FADE_START) / (TOTAL - FADE_START));

        if (p.y < canvas.height + 30 && p.alpha > 0) {
          alive = true;
          c.save();
          c.globalAlpha = p.alpha;
          c.fillStyle   = p.color;
          c.translate(p.x, p.y);
          c.rotate(p.rot);
          if (p.circle) {
            c.beginPath();
            c.arc(0, 0, p.w / 2, 0, Math.PI * 2);
            c.fill();
          } else {
            c.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
          }
          c.restore();
        }
      }

      if (alive && elapsed < TOTAL + 200) requestAnimationFrame(tick);
      else canvas.remove();
    })(performance.now());
  }

  document.fonts.ready.then(() => document.body.classList.add('fonts-ready'));

  render();
</script>

<style is:global>
  :root {
    --yellow: #FFE141;
    --coral:  #FF3358;
    --teal:   #00C9B1;
    --lav:    #C4B5FD;
    --ink:    #1A1A1A;
    --cell:   46px;
    --gap:    6px;
    --wgap:   22px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    min-height: 100vh;
    background-color: var(--yellow);
    background-image: radial-gradient(rgba(26,26,26,0.1) 1.5px, transparent 1.5px);
    background-size: 28px 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Unbounded', sans-serif;
    padding: 2rem 1rem;
  }

  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
  }

  @keyframes enterUp {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── Card ─── */
  .card {
    animation: enterUp 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-play-state: paused;
    background: #fff;
    background-image: radial-gradient(rgba(26,26,26,0.04) 1px, transparent 1px);
    background-size: 18px 18px;
    border: 4px solid var(--ink);
    border-radius: 28px;
    box-shadow: 8px 8px 0 var(--ink);
    padding: 2rem;
    display: inline-flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* ─── Header ─── */
  .header { display: flex; flex-direction: column; gap: 0.5rem; }

  .title {
    font-weight: 900;
    font-size: clamp(1.1rem, 5vw, 1.55rem);
    color: var(--coral);
    line-height: 1.1;
    letter-spacing: -0.03em;
    text-transform: lowercase;
  }

  .subtitle {
    font-size: clamp(0.7rem, 2.8vw, 0.88rem);
    font-weight: 700;
    color: var(--teal);
    line-height: 1.3;
    letter-spacing: -0.01em;
    text-transform: lowercase;
  }

/* ─── Grid ─── */
  .grid {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .row {
    display: flex;
    align-items: center;
    gap: var(--gap);
  }

  /* ─── Cells ─── */
  .cell {
    width: var(--cell);
    height: var(--cell);
    border-radius: 8px;
    background: #DCDCDC;         /* light grey — empty block */
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 900;
    color: var(--ink);
    flex-shrink: 0;
    transition: transform 0.08s ease, background 0.12s ease;
  }

  /* letter typed but not yet submitted */
  .cell[data-state="typed"] {
    background: #C4C4C4;
    transform: scale(1.07);
  }

  /* submitted results */
  .cell[data-state="correct"] {
    background: var(--coral);
    color: #fff;
  }

  .cell[data-state="present"] {
    background: var(--yellow);
    color: var(--ink);
  }

  .cell[data-state="absent"] {
    background: #888;
    color: rgba(255,255,255,0.7);
  }

  /* gap between words */
  .word-gap {
    width: var(--wgap);
    flex-shrink: 0;
  }

  /* ─── Instruction ─── */
  .instruct {
    font-size: 0.5rem;
    font-weight: 700;
    color: rgba(26,26,26,0.28);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ─── Result ─── */
  .result:not(:empty) {
    background: var(--ink);
    border-radius: 14px;
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .msg-win {
    font-size: 1rem;
    font-weight: 900;
    color: var(--yellow);
    letter-spacing: -0.02em;
  }

  .msg-sub {
    font-size: 0.58rem;
    font-weight: 700;
    color: rgba(255,255,255,0.45);
  }

  .msg-sub em {
    font-style: normal;
    color: var(--teal);
  }

  body.fonts-ready .card {
    animation-play-state: running;
  }

  body.fonts-ready .back {
    animation-play-state: running;
  }

  /* ─── Back home ─── */
  .back {
    animation: enterUp 0.7s 0.08s cubic-bezier(0.34, 1.56, 0.64, 1) both;
    animation-play-state: paused;
    display: inline-flex;
    align-items: center;
    padding: 11px 20px;
    border: 3px solid var(--ink);
    border-radius: 100px;
    background: var(--ink);
    color: var(--yellow);
    font-family: 'Unbounded', sans-serif;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 4px 4px 0 rgba(26,26,26,0.3);
    transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.22s ease;
  }

  .back:hover {
    transform: translateY(-6px);
    box-shadow: 7px 7px 0 rgba(26,26,26,0.3);
  }
</style>
