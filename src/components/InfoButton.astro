---
// Info button — sits fixed next to HomeButton on project pages
// Pass project description via the default slot
---

<button class="info-btn" aria-label="About this project" id="info-btn">?</button>

<div class="info-overlay" id="info-overlay" aria-hidden="true">
  <div class="info-modal" role="dialog" aria-modal="true">
    <button class="info-close" id="info-close" aria-label="Close">✕</button>
    <div class="info-content">
      <slot />
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('info-btn');
  const overlay = document.getElementById('info-overlay');
  const close = document.getElementById('info-close');

  btn?.addEventListener('click', () => {
    overlay?.classList.add('open');
    overlay?.removeAttribute('aria-hidden');
  });

  close?.addEventListener('click', () => {
    overlay?.classList.remove('open');
    overlay?.setAttribute('aria-hidden', 'true');
  });

  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) {
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      overlay?.classList.remove('open');
      overlay?.setAttribute('aria-hidden', 'true');
    }
  });
</script>

<style>
  .info-btn {
    position: fixed;
    top: 20px;
    left: 76px;
    z-index: 1000;
    width: 48px;
    height: 48px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    font-family: 'Arial Black', Arial, sans-serif;
    font-weight: 900;
    font-size: 32px;
    line-height: 1;
    color: rgba(136, 136, 136, 0.45);
    opacity: 0.7;
    font-size: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      opacity 0.2s ease,
      transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .info-btn:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  /* Overlay */
  .info-overlay {
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .info-overlay.open {
    opacity: 1;
    pointer-events: all;
  }

  /* Modal */
  .info-modal {
    background: #fff;
    border-radius: 20px;
    padding: 2.5rem;
    max-width: 480px;
    width: calc(100% - 3rem);
    position: relative;
    transform: translateY(12px) scale(0.97);
    transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.15);
  }

  .info-overlay.open .info-modal {
    transform: translateY(0) scale(1);
  }

  .info-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    border: none;
    background: rgba(0, 0, 0, 0.07);
    border-radius: 8px;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555;
    transition: background 0.15s ease;
  }

  .info-close:hover {
    background: rgba(0, 0, 0, 0.13);
  }

  .info-content {
    font-family: system-ui, sans-serif;
    font-size: 0.95rem;
    line-height: 1.7;
    color: #333;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
</style>
