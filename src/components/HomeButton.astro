---
// Translucent home button — sits fixed on every project page
---

<a href="/" class="home-btn" aria-label="Back to evie makes">
  <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <mask id="home-btn-mask">
        <rect width="32" height="32" rx="8" fill="white"/>
        <text x="4" y="24" font-size="22" font-weight="900"
              font-family="Arial Black, Arial, sans-serif" fill="black">e</text>
        <text x="19" y="14" font-size="10" font-family="sans-serif" fill="black">✦</text>
      </mask>
    </defs>
    <rect width="32" height="32" rx="8" fill="#888" fill-opacity="0.45" mask="url(#home-btn-mask)"/>
  </svg>
</a>

<style>
  .home-btn {
    position: fixed;
    top: 20px;
    left: 20px;
    z-index: 1000;
    display: block;
    width: 48px;
    height: 48px;
    text-decoration: none;
    opacity: 0.7;
    transition:
      opacity 0.2s ease,
      transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .home-btn:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .home-btn svg {
    width: 100%;
    height: 100%;
  }
</style>
